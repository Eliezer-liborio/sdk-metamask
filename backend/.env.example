# Configurações da API SDK MetaMask
# Copie este arquivo para .env e preencha os valores

# URL do provedor RPC Ethereum (ex: Alchemy, Infura)
# Necessário apenas para suporte a Smart Contract Wallets (EIP-1271)
ALCHEMY_API_URL=https://eth-mainnet.g.alchemy.com/v2/SUA_CHAVE_AQUI

# Domínio do servidor (sem protocolo)
# Em desenvolvimento: localhost
# Em produção: seudominio.com
DOMAIN=localhost

# Declaração exibida ao usuário no momento da assinatura
STATEMENT=Ao assinar esta mensagem, você autentica sua identidade de forma segura e sem senha.

# Chain ID da rede Ethereum
# 1 = Mainnet, 11155111 = Sepolia, 137 = Polygon
CHAIN_ID=1

# Tempo de vida do nonce em segundos (padrão: 300 = 5 minutos)
NONCE_TTL_SECONDS=300
